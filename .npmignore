# `package.json#files` is the source of truth for what ships:
#   bin/cli.mjs · .next/standalone · README.md · LICENSE
#
# This file is belt-and-suspenders: it stops build leftovers from sneaking in
# if someone widens `files` in the future. Rules outside the whitelist (app/,
# components/, lib/, scripts/, configs, lockfiles, source) don't need listing —
# `files` already excludes them.

# Build leftovers that live OUTSIDE .next/standalone — never ship.
.next/cache/
.next/trace
.next/build-manifest.json
.next/prerender-manifest.json
.next/required-server-files.json

# Dev artefacts
*.log
.DS_Store
.idea/
.vscode/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*

# Optional design / planning notes
PLAN.md
docs/

# Marketing website lives in this repo but ships independently to its own
# host (Cloudflare Pages / Vercel / Netlify). Belt-and-suspenders only —
# package.json#files already excludes it implicitly.
site/
