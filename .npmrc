registry=https://registry.npmjs.org/
auto-install-peers=true
strict-peer-dependencies=false

# Use a flat (npm-style) node_modules instead of pnpm's symlink + .pnpm layout.
# Reason: Next.js `output: 'standalone'` copies the on-disk module layout into
# `.next/standalone`, and `npm pack` / `pnpm pack` silently drop symlinks. With
# the default isolated linker, the published tarball ends up missing top-level
# packages like `next` and breaks at runtime. Hoisted layout sidesteps this.
node-linker=hoisted
