---
import type { Locale } from '../consts';
import ThemedScreenshot from './ThemedScreenshot.astro';

interface Props {
  /** Optional icon emoji or single character; falls back to a brand dot. */
  icon?: string;
  title: string;
  /** Short 1-2 sentence description. */
  body: string;
  /** Image src (relative to /images/). */
  imageSrc?: string;
  imageAlt?: string;
  /** Screenshot basename under /images/screenshots, rendered for the current locale + theme. */
  screenshotName?: string;
  screenshotLocale?: Locale;
  /** Optional CTA: { label, href } */
  ctaLabel?: string;
  ctaHref?: string;
}

const { icon, title, body, imageSrc, imageAlt, screenshotName, screenshotLocale, ctaLabel, ctaHref } = Astro.props;
const hasMedia = Boolean(screenshotName || imageSrc);
---

<article class="card card-interactive flex flex-col overflow-hidden">
  {hasMedia && (
    <div class="aspect-[16/10] bg-bg-surface-hi border-b border-border overflow-hidden">
      {screenshotName && screenshotLocale ? (
        <ThemedScreenshot name={screenshotName} locale={screenshotLocale} alt={imageAlt ?? ''} />
      ) : (
        <img
          src={`/images/${imageSrc}`}
          alt={imageAlt ?? ''}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      )}
    </div>
  )}
  <div class="card-pad flex flex-col gap-2 flex-1">
    <div class="flex items-center gap-2">
      {icon ? (
        <span class="text-lg" aria-hidden="true">{icon}</span>
      ) : (
        <span class="inline-block h-2 w-2 rounded-full bg-brand" aria-hidden="true"></span>
      )}
      <h3 class="font-semibold text-text-primary text-base tracking-tight">{title}</h3>
    </div>
    <p class="text-sm text-text-secondary leading-relaxed flex-1">{body}</p>
    {ctaLabel && ctaHref && (
      <a
        href={ctaHref}
        class="mt-2 text-sm font-medium text-brand hover:text-brand-hover inline-flex items-center gap-1"
      >
        {ctaLabel} <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
</article>
