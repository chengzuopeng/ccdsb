---
import type { Locale } from '../consts';
import ThemedScreenshot from './ThemedScreenshot.astro';

interface Props {
  src?: string;
  screenshotName?: string;
  locale?: Locale;
  alt: string;
  /** Visual width hint — controls aspect ratio. Defaults to 16:10. */
  ratio?: '16/10' | '16/9' | '4/3';
  /** Caption shown below the screenshot. Optional. */
  caption?: string;
}

const { src, screenshotName, locale, alt, ratio = '16/10', caption } = Astro.props;
const ratioClass =
  ratio === '16/9' ? 'aspect-[16/9]' : ratio === '4/3' ? 'aspect-[4/3]' : 'aspect-[16/10]';
---

<figure class="mx-auto max-w-5xl">
  <div class="rounded-card border border-border-hi bg-bg-surface shadow-card overflow-hidden">
    <!-- Mac-style title bar so the screenshot reads as "an app", not "a stray PNG". -->
    <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-border bg-bg-surface-hi">
      <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-yellow-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-green-400/80"></span>
      <span class="ml-3 text-[11px] font-mono text-text-tertiary tabular-nums">ccgauge — localhost:3737</span>
    </div>
    <div class:list={['bg-bg-surface-hi', ratioClass]}>
      {screenshotName && locale ? (
        <ThemedScreenshot name={screenshotName} locale={locale} alt={alt} loading="eager" />
      ) : src ? (
        <img src={src} alt={alt} loading="eager" decoding="async" class="w-full h-full object-cover" />
      ) : null}
    </div>
  </div>
  {caption && <figcaption class="mt-4 text-center text-sm text-text-tertiary">{caption}</figcaption>}
</figure>
