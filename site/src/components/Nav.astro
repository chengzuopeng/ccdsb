---
import { useTranslations, localePath } from '../i18n/utils';
import { GITHUB_URL, SITE_TITLE, type Locale } from '../consts';
import LangSwitch from './LangSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const items: Array<{ key: 'nav.home' | 'nav.features' | 'nav.cli' | 'nav.mcp' | 'nav.privacy'; path: string }> = [
  { key: 'nav.home', path: '' },
  { key: 'nav.features', path: 'features' },
  { key: 'nav.cli', path: 'cli' },
  { key: 'nav.mcp', path: 'mcp' },
  { key: 'nav.privacy', path: 'privacy' },
];

// "Active" = the current URL starts with the item's localePath. Home is a
// special case — only matches the bare locale root, otherwise EVERY page
// would highlight Home.
function isActive(itemPath: string): boolean {
  const fullPath = localePath(locale, itemPath);
  const here = Astro.url.pathname;
  if (itemPath === '') return here === fullPath;
  return here.startsWith(fullPath);
}
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 h-14 flex items-center gap-4">
    <a
      href={localePath(locale, '')}
      class="flex items-center gap-2 shrink-0 hover:opacity-80 transition-opacity"
      aria-label={SITE_TITLE}
    >
      <span
        class="inline-flex h-7 w-7 items-center justify-center rounded-button"
        style="background: rgb(var(--brand-strong));"
        aria-hidden="true"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-linecap="round" aria-hidden="true">
          <!-- Dial track (180° arc) -->
          <path d="M5 15.5 A6.5 6.5 0 0 1 18 15.5" stroke-opacity="0.32" stroke-width="2" fill="none"/>
          <!-- Progress arc, ends on the rim at 60° elevation -->
          <path d="M5 15.5 A6.5 6.5 0 0 1 14.75 9.87" stroke-width="2" fill="none"/>
          <!-- Needle — pivot to rim -->
          <line x1="11.5" y1="15.5" x2="14.75" y2="9.87" stroke-width="1.6"/>
          <!-- Pivot dot -->
          <circle cx="11.5" cy="15.5" r="1.6" fill="white" stroke="none"/>
        </svg>
      </span>
      <span class="font-semibold text-text-primary text-[15px] tracking-tight">{SITE_TITLE}</span>
    </a>

    <nav class="hidden md:flex items-center gap-1 ml-2" aria-label="Primary">
      {items.map(({ key, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'px-3 py-1.5 rounded-button text-sm font-medium transition-colors',
            isActive(path)
              ? 'text-text-primary bg-bg-surface-hi'
              : 'text-text-secondary hover:text-text-primary hover:bg-bg-surface-hi',
          ]}
        >
          {t(key)}
        </a>
      ))}
    </nav>

    <div class="flex-1"></div>

    <div class="flex items-center gap-2">
      <ThemeToggle locale={locale} />
      <LangSwitch locale={locale} />
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-button text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-bg-surface-hi transition-colors"
        aria-label={t('nav.github')}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.58.1.79-.25.79-.55v-2.1c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.45.11-3.03 0 0 .96-.31 3.15 1.18a10.94 10.94 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.24 2.74.12 3.03.73.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.18c0 .31.21.66.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
        </svg>
        <span class="hidden lg:inline">{t('nav.github')}</span>
      </a>
    </div>
  </div>

  <!-- Mobile nav (revealed by media query, no JS — content scrolls horizontally) -->
  <nav
    class="md:hidden border-t border-border overflow-x-auto"
    aria-label="Primary"
    style="scrollbar-width: none;"
  >
    <div class="flex items-center gap-1 px-4 py-2 whitespace-nowrap">
      {items.map(({ key, path }) => (
        <a
          href={localePath(locale, path)}
          class:list={[
            'px-3 py-1 rounded-button text-sm font-medium transition-colors',
            isActive(path)
              ? 'text-text-primary bg-bg-surface-hi'
              : 'text-text-secondary hover:text-text-primary',
          ]}
        >
          {t(key)}
        </a>
      ))}
    </div>
  </nav>
</header>
