---
import { useTranslations, localePath } from '../i18n/utils';
import { GITHUB_URL, NPM_URL, SITE_TITLE, type Locale } from '../consts';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

const columns: Array<{
  title: string;
  items: Array<{ label: string; href: string; external?: boolean }>;
}> = [
  {
    title: locale === 'zh' ? '产品' : 'Product',
    items: [
      { label: t('nav.features'), href: localePath(locale, 'features') },
      { label: t('nav.cli'), href: localePath(locale, 'cli') },
      { label: t('nav.mcp'), href: localePath(locale, 'mcp') },
      { label: t('nav.privacy'), href: localePath(locale, 'privacy') },
    ],
  },
  {
    title: locale === 'zh' ? '资源' : 'Resources',
    items: [
      { label: 'GitHub', href: GITHUB_URL, external: true },
      { label: 'npm', href: NPM_URL, external: true },
      {
        label: locale === 'zh' ? '提交问题' : 'Report an issue',
        href: GITHUB_URL + '/issues',
        external: true,
      },
    ],
  },
];
---

<footer class="border-t border-border mt-16 sm:mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      <div class="col-span-2">
        <div class="flex items-center gap-2 mb-3">
          <span
            class="inline-flex h-7 w-7 items-center justify-center rounded-button"
            style="background: rgb(var(--brand-strong));"
            aria-hidden="true"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-linecap="round" aria-hidden="true">
              <!-- Dial track (180° arc) -->
              <path d="M5 15.5 A6.5 6.5 0 0 1 18 15.5" stroke-opacity="0.32" stroke-width="2" fill="none"/>
              <!-- Progress arc, ends on the rim at 60° elevation -->
              <path d="M5 15.5 A6.5 6.5 0 0 1 14.75 9.87" stroke-width="2" fill="none"/>
              <!-- Needle — pivot to rim -->
              <line x1="11.5" y1="15.5" x2="14.75" y2="9.87" stroke-width="1.6"/>
              <!-- Pivot dot -->
              <circle cx="11.5" cy="15.5" r="1.6" fill="white" stroke="none"/>
            </svg>
          </span>
          <span class="font-semibold text-text-primary text-[15px] tracking-tight">{SITE_TITLE}</span>
        </div>
        <p class="text-sm text-text-secondary max-w-sm leading-relaxed">{t('footer.tagline')}</p>
        <p class="text-xs text-text-tertiary mt-4">
          © {year} ccgauge contributors. {t('footer.license')}
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="label mb-3">{col.title}</h3>
          <ul class="space-y-2">
            {col.items.map((it) => (
              <li>
                <a
                  href={it.href}
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors"
                  {...(it.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {it.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
