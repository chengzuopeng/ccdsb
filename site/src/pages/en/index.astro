---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ScreenshotFrame from '../../components/ScreenshotFrame.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import CtaRow from '../../components/CtaRow.astro';
import { localePath } from '../../i18n/utils';
import { GITHUB_URL } from '../../consts';

const locale = 'en';
const installSnippet = 'npx ccgauge';
const mcpSnippet = `{
  "mcpServers": {
    "ccgauge": {
      "command": "npx",
      "args": ["-y", "ccgauge", "mcp"]
    }
  }
}`;
---

<BaseLayout
  locale={locale}
  title="ccgauge"
  description="Local web dashboard, CLI, and MCP server for Claude Code and OpenAI Codex CLI token usage and cost — runs on your machine, never calls home."
>
  <Hero
    eyebrow="Stable · 100% local"
    title="See how many tokens your AI coding CLIs"
    titleAccent="actually use."
    lede="ccgauge is a local-only dashboard for Claude Code and OpenAI Codex CLI. Track tokens, cost, cache savings, and 5h-block usage across every project, model, and session — without sending a single byte off your machine."
    screenshotName="overview"
    screenshotLocale={locale}
    imageAlt="Real ccgauge overview dashboard screenshot in dark mode, showing KPI cards, token trend chart, cache hit rate, and active 5-hour block."
  >
    <a slot="cta" href={GITHUB_URL} class="btn-brand" target="_blank" rel="noopener noreferrer">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.58.1.79-.25.79-.55v-2.1c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.45.11-3.03 0 0 .96-.31 3.15 1.18a10.94 10.94 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.24 2.74.12 3.03.73.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.18c0 .31.21.66.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
      </svg>
      Star on GitHub
    </a>
    <a slot="cta" href={localePath(locale, 'features')} class="btn">
      Explore features
      <span aria-hidden="true">→</span>
    </a>
    <div slot="below-cta" class="mt-8 max-w-md">
      <CodeBlock code={installSnippet} lang="bash" />
      <p class="mt-3 text-xs text-text-tertiary">
        One command. Opens a dashboard at <span class="font-mono">localhost:3737</span>. No login,
        no telemetry, no API keys.
      </p>
    </div>
  </Hero>

  <!-- Trust strip / one-liner under the hero -->
  <section class="border-y border-border bg-bg-surface">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 py-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-xs text-text-tertiary uppercase tracking-[0.08em]">
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand"></span> Claude Code</span>
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-orange-400"></span> OpenAI Codex CLI</span>
      <span>100% local</span>
      <span>MIT licensed</span>
      <span>macOS · Linux · Windows</span>
      <span>English / 中文</span>
    </div>
  </section>

  <FeatureGrid
    eyebrow="Why ccgauge"
    title="Six things that make ccgauge worth the 10-second install."
    description="Every feature is built around two ideas: your data stays on your machine, and you get answers in seconds — not after building a spreadsheet."
  >
    <FeatureCard
      icon="◇"
      title="Multi-source analytics"
      body="One unified dashboard for Claude Code, OpenAI Codex CLI, or both merged in an All view. Real provider logos, persisted via URL + cookie."
      imageSrc="screenshots/models-en-dark.png"
      imageAlt="ccgauge Models page comparing per-model token spend across Claude and Codex side by side."
    />
    <FeatureCard
      icon="▣"
      title="CLI report"
      body={'No server, no browser — just `ccgauge report`. Colored summary, trend chart, top-N breakdown, JSON output. Pipes cleanly into your scripts.'}
      imageSrc="feature-cli.webp"
      imageAlt="Generated terminal-style report visual with cost and token analytics."
      ctaLabel="Read the CLI reference"
      ctaHref={localePath(locale, 'cli')}
    />
    <FeatureCard
      icon="◈"
      title="MCP server"
      body="Let Claude Desktop / Cursor / Cline query your usage directly. Eight MCP tools cover totals, time series, per-model and per-session breakdowns."
      imageSrc="feature-mcp.webp"
      imageAlt="Generated MCP integration visual with a local server node connected to structured usage tools."
      ctaLabel="MCP integration guide"
      ctaHref={localePath(locale, 'mcp')}
    />
    <FeatureCard
      icon="⌬"
      title="Activity heatmap"
      body="7×24 day-of-week × hour-of-day grid with hover tooltips for message counts, tokens, and share-of-total. Find your peak coding hours at a glance."
      imageSrc="feature-heatmap.webp"
      imageAlt="Generated analytics visual focused on a 7 by 24 activity heatmap and hover tooltip."
    />
    <FeatureCard
      icon="🔒"
      title="100% local, zero telemetry"
      body="ccgauge reads your existing JSONL session files and never makes outbound calls. Bind to 127.0.0.1 by default. Open source, MIT."
      imageSrc="feature-privacy.webp"
      imageAlt="Generated local privacy visual with a shield, locked files, and a blocked outbound network path."
      ctaLabel="Privacy by design"
      ctaHref={localePath(locale, 'privacy')}
    />
    <FeatureCard
      icon="🌐"
      title="Bilingual, themeable"
      body="English and 简体中文 throughout the UI and CLI. Dark / light / system themes with no flash on first paint. Cross-platform npm install."
      imageSrc="feature-i18n.webp"
      imageAlt="Generated bilingual and theme-switching visual with dark and light dashboard panels."
    />
  </FeatureGrid>

  <!-- Real screenshot showcase — usage drill-down, complements the hero -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-20">
    <div class="max-w-2xl mb-10">
      <div class="pill-brand mb-3">Drill down to a single call</div>
      <h2 class="heading-section">From monthly spend to the exact API call.</h2>
      <p class="lede mt-3">
        Every assistant call is grouped into its real conversation turn. Expand a turn to see
        each call's tool list, prompt fragment, and cost — search, filter, sort, export.
      </p>
    </div>
    <ScreenshotFrame
      screenshotName="usage"
      locale={locale}
      alt="ccgauge Usage page screenshot, showing the turn-grouped table with expandable tool-call rows, search box, and CSV export button."
      caption="Usage · turn-grouped table with expand · CSV export"
    />
  </section>

  <!-- Methodology teaser -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-8 lg:gap-12 items-start">
      <div>
        <div class="pill-brand mb-3">How the numbers work</div>
        <h2 class="heading-section">Honest math. No black box.</h2>
        <p class="lede mt-3 max-w-md">
          Token counts come straight from the JSONL your CLI already writes. Cost uses ccgauge's
          built-in price tables for each model.
        </p>
        <a
          href={localePath(locale, 'features') + '#methodology'}
          class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand hover:text-brand-hover"
        >
          See the full methodology <span aria-hidden="true">→</span>
        </a>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <li class="card card-pad">
          <div class="label mb-2">Token counts</div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Read directly from the assistant records in your CLI's JSONL files. We dedupe identical
            <span class="font-mono text-xs">(messageId, requestId)</span> pairs across sub-agent forks.
          </p>
        </li>
        <li class="card card-pad">
          <div class="label mb-2">Cost calculation</div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Per-million-token rates per model. Unknown variants fall back to the family-latest rate
            (e.g. <span class="font-mono text-xs">gpt-5.5-foo</span> → <span class="font-mono text-xs">gpt-5.5</span>).
          </p>
        </li>
        <li class="card card-pad">
          <div class="label mb-2">Cache savings</div>
          <p class="text-sm text-text-secondary leading-relaxed">
            We compute what you would have paid if every cache-hit had been a fresh read at full
            input rate, and show the delta as "Saved by cache".
          </p>
        </li>
        <li class="card card-pad">
          <div class="label mb-2">5h block tracker</div>
          <p class="text-sm text-text-secondary leading-relaxed">
            Wall-clock progress of the active 5-hour conversation window. <em>Not</em> Anthropic's
            plan-quota counter — that lives server-side and isn't exposed to clients.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <!-- MCP teaser -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-14 sm:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div>
        <div class="pill-brand mb-3">MCP-ready</div>
        <h2 class="heading-section">Let your LLM read its own usage.</h2>
        <p class="lede mt-3">
          Add three lines to Claude Desktop's config and ask the model: <em>"how much did
          I spend on Opus this week broken down by project?"</em> Eight MCP tools answer that
          and a dozen variations like it.
        </p>
        <a href={localePath(locale, 'mcp')} class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand hover:text-brand-hover">
          See all 8 MCP tools <span aria-hidden="true">→</span>
        </a>
      </div>
      <div>
        <CodeBlock code={mcpSnippet} lang="json" />
      </div>
    </div>
  </section>

  <CtaRow
    title="Install in 10 seconds."
    description="One command — opens a local dashboard, no signup. Stop guessing what Claude Code costs you."
  >
    <a href={GITHUB_URL} class="btn-brand" target="_blank" rel="noopener noreferrer">
      Star on GitHub
    </a>
    <a href={localePath(locale, 'features')} class="btn">
      Tour the features <span aria-hidden="true">→</span>
    </a>
  </CtaRow>
</BaseLayout>
