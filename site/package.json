{
  "name": "ccgauge-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Marketing / docs website for ccgauge. Independent build, not published to npm.",
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build",
    "preview": "astro preview --port 4322",
    "check": "astro check",
    "gen:placeholders": "node scripts/gen-placeholders.mjs",
    "clean": "node -e \"for (const p of ['dist','.astro','node_modules']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "astro": "^4.16.18",
    "@astrojs/tailwind": "^5.1.4",
    "@astrojs/check": "^0.9.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "@fontsource-variable/geist": "^5.1.1",
    "@fontsource-variable/geist-mono": "^5.1.1"
  }
}
