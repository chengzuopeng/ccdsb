{
  "name": "ccgauge",
  "version": "0.1.1",
  "description": "Claude Code Dashboard — local web UI for Claude Code token usage and cost",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "usage",
    "dashboard",
    "cli",
    "tokens",
    "cost"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "bin": {
    "ccgauge": "bin/cli.mjs"
  },
  "files": [
    "bin/cli.mjs",
    ".next/standalone",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev -p 3737",
    "build": "next build && node scripts/postbuild.mjs",
    "start": "node bin/cli.mjs",
    "start:next": "next start -p 3737",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next node_modules tsconfig.tsbuildinfo",
    "screenshots": "node scripts/screenshots.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "get-port": "^7.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "next": "^15.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "zod": "^3.24.1"
  }
}
