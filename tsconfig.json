{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "bin/cli.mjs",
    "scripts/**",
    // The marketing site (`site/`) has its own Astro tsconfig and its own
    // `pnpm check` step. Excluding it here keeps root `tsc --noEmit` fast
    // and stops Astro / Vite type definitions from leaking into the main
    // repo's compile graph.
    "site/**"
  ]
}
